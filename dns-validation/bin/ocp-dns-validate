#!/usr/bin/env bash
# OpenShift DNS validation automation with text menu frontend.
set -Eeuo pipefail

SCRIPT_NAME="$(basename "$0")"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG_FILE="$PROJECT_DIR/config/validation.env"
ACTION="menu"
AUTO_YES="false"

usage() {
  cat <<USAGE
Usage: $SCRIPT_NAME [--config FILE] [--yes] <action>

Actions:
  menu                 Interactive text frontend
  init                 Check local tools and create artifact directories
  preflight            Capture cluster and DNS baseline
  extract-tests        Extract release-matched openshift-tests
  discover-dns-tests   Discover DNS conformance tests
  run-dns-tests        Run discovered DNS conformance tests
  run-single-test      Run one openshift-tests test by full name
  node-sweep           Run DNS smoke checks from one pod per node
  generate-queries     Generate dnsperf query file
  dnsperf              Run direct dnsperf QPS ladder against cluster DNS
  perf-tests           Optional kubernetes/perf-tests/dns quick profile
  report               Generate markdown report
  cleanup              Delete validation namespace
  all                  Run recommended sequence

Examples:
  bash bin/ocp-dns-validate --config config/validation.env menu
  bash bin/ocp-dns-validate preflight
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--config) CONFIG_FILE="$2"; shift 2 ;;
    -y|--yes) AUTO_YES="true"; shift ;;
    -h|--help) usage; exit 0 ;;
    *) ACTION="$1"; shift ;;
  esac
done

if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

RUN_ID="${RUN_ID:-$(date +%Y%m%d-%H%M%S)}"
ARTIFACT_ROOT="${ARTIFACT_ROOT:-$PROJECT_DIR/runs}"
ARTIFACT_DIR="${ARTIFACT_DIR:-$ARTIFACT_ROOT/$RUN_ID}"
VALIDATION_NAMESPACE="${VALIDATION_NAMESPACE:-dns-validation}"
PULL_SECRET_FILE="${PULL_SECRET_FILE:-$HOME/pull-secret.json}"
DNS_TEST_REGEX="${DNS_TEST_REGEX:-dns|\[sig-network\].*DNS}"
INCLUDE_SERIAL_DNS_TESTS="${INCLUDE_SERIAL_DNS_TESTS:-false}"
DNS_SWEEP_IMAGE="${DNS_SWEEP_IMAGE:-registry.k8s.io/e2e-test-images/jessie-dnsutils:1.3}"
DNSPERF_IMAGE="${DNSPERF_IMAGE:-docker.io/guessi/dnsperf:latest}"
DNSPERF_QPS_STEPS="${DNSPERF_QPS_STEPS:-100 500 1000 2000}"
DNSPERF_DURATION_SECONDS="${DNSPERF_DURATION_SECONDS:-60}"
DNSPERF_CLIENTS="${DNSPERF_CLIENTS:-5}"
DNSPERF_THREADS="${DNSPERF_THREADS:-2}"
DNSPERF_STATS_INTERVAL="${DNSPERF_STATS_INTERVAL:-10}"
DNSPERF_EXTRA_ARGS="${DNSPERF_EXTRA_ARGS:-}"
QUERY_REPEAT_COUNT="${QUERY_REPEAT_COUNT:-1000}"
CUSTOM_QUERY_SEED="${CUSTOM_QUERY_SEED:-$PROJECT_DIR/queries/custom.seed.txt}"
PERF_TESTS_REPO="${PERF_TESTS_REPO:-https://github.com/kubernetes/perf-tests.git}"
PERF_TESTS_REF="${PERF_TESTS_REF:-master}"
PERF_TESTS_MODE="${PERF_TESTS_MODE:-cluster-dns}"
PERF_TESTS_RUN_LENGTH_SECONDS="${PERF_TESTS_RUN_LENGTH_SECONDS:-60}"
PERF_TESTS_MAX_QPS="${PERF_TESTS_MAX_QPS:-500 1000 2000}"
LOG_FILE="$ARTIFACT_DIR/ocp-dns-validate.log"
RUNTIME_ENV="$ARTIFACT_DIR/runtime.env"
OPENSHIFT_TESTS_BIN="$ARTIFACT_DIR/01-openshift-tests/openshift-tests"

mkdir -p "$ARTIFACT_DIR"

# shellcheck source=../lib/common.sh
source "$PROJECT_DIR/lib/common.sh"
# shellcheck source=../lib/cluster.sh
source "$PROJECT_DIR/lib/cluster.sh"
# shellcheck source=../lib/perf.sh
source "$PROJECT_DIR/lib/perf.sh"

menu() {
  init_dirs
  while true; do
    cat <<MENU

OpenShift DNS Validation
Artifact directory: $ARTIFACT_DIR
Namespace:          $VALIDATION_NAMESPACE

  1) Init/check local tools
  2) Preflight cluster + DNS baseline
  3) Extract release-matched openshift-tests
  4) Discover DNS conformance tests
  5) Run DNS conformance subset
  6) Run one openshift-tests test by full name
  7) Node-level DNS sweep
  8) Generate dnsperf query file
  9) Run direct dnsperf QPS ladder
 10) Run optional kubernetes/perf-tests/dns quick profile
 11) Generate markdown report
 12) Cleanup validation namespace
 13) Run recommended sequence
 14) Show artifact paths
  q) Quit
MENU
    read -r -p "Select action: " choice
    case "$choice" in
      1) init_action ;;
      2) preflight ;;
      3) extract_tests ;;
      4) discover_dns_tests ;;
      5) run_dns_tests ;;
      6) run_single_test ;;
      7) node_sweep ;;
      8) generate_queries ;;
      9) run_dnsperf ;;
      10) run_perf_tests ;;
      11) report ;;
      12) cleanup ;;
      13) all_actions ;;
      14) show_paths ;;
      q|Q) break ;;
      *) echo "Unknown choice: $choice" ;;
    esac
  done
}

case "$ACTION" in
  menu) menu ;;
  init) init_action ;;
  preflight) preflight ;;
  extract-tests) extract_tests ;;
  discover-dns-tests) discover_dns_tests ;;
  run-dns-tests) run_dns_tests ;;
  run-single-test) run_single_test ;;
  node-sweep) node_sweep ;;
  generate-queries) generate_queries ;;
  dnsperf) run_dnsperf ;;
  perf-tests) run_perf_tests ;;
  report) report ;;
  cleanup) cleanup ;;
  all) all_actions ;;
  *) usage; exit 2 ;;
esac
