# OpenShift DNS validation automation configuration
# Copy this file to validation.env and edit local values.

# Artifact location. If ARTIFACT_DIR is unset, a timestamped directory under ARTIFACT_ROOT is used.
ARTIFACT_ROOT="./runs"
# ARTIFACT_DIR=""

# Temporary namespace used for node sweep and dnsperf workloads.
VALIDATION_NAMESPACE="dns-validation"

# Pull secret used to extract release-matched openshift-tests.
# Keep the real pull secret path in validation.env, not in Git.
PULL_SECRET_FILE="$HOME/pull-secret.json"

# DNS conformance discovery options.
DNS_TEST_REGEX="dns|\[sig-network\].*DNS"
# Pipe-separated extended grep pattern of discovered test names to omit; leave empty to run all matches.
DNS_TEST_EXCLUDE_REGEX="DNS should answer A and AAAA queries for a dual-stack service|DNS should answer queries using the local DNS endpoint"
INCLUDE_SERIAL_DNS_TESTS="false"

# Node-level DNS sweep image. Replace with an internally mirrored image if required.
DNS_SWEEP_IMAGE="registry.k8s.io/e2e-test-images/jessie-dnsutils:1.3"

# dnsperf image. For customer or regulated environments, use an approved pinned internal image.
DNSPERF_IMAGE="docker.io/guessi/dnsperf:2.15.1-1"
DNSPERF_QPS_STEPS="100 500 1000 2000"
DNSPERF_DURATION_SECONDS="60"
DNSPERF_CLIENTS="5"
DNSPERF_THREADS="2"
DNSPERF_STATS_INTERVAL="10"
DNSPERF_EXTRA_ARGS=""
# Optional dnsperf verdict thresholds. Leave empty to gate only on dnsperf command rc per QPS step.
DNSPERF_MAX_LOST_PERCENT=""
DNSPERF_MAX_AVG_LATENCY_SECONDS=""
QUERY_REPEAT_COUNT="1000"

# Optional custom dnsperf query seed. If this file exists, it overrides generated defaults.
CUSTOM_QUERY_SEED="./queries/custom.seed.txt"

# Optional kubernetes/perf-tests/dns integration.
PERF_TESTS_REPO="https://github.com/kubernetes/perf-tests.git"
PERF_TESTS_REF="v1.31.0"
# Supported: cluster-dns, dns-ip, isolated-coredns
PERF_TESTS_MODE="cluster-dns"
PERF_TESTS_RUN_LENGTH_SECONDS="60"
PERF_TESTS_MAX_QPS="500 1000 2000"
