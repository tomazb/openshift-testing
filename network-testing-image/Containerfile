FROM registry.access.redhat.com/ubi9/ubi:latest

RUN dnf install -y \
    tcpdump \
    traceroute \
    iperf3 \
    fio \
    rsync \
    curl \
    wget \
    && dnf clean all

RUN ARCH=$(uname -m) && \
    if [ "${ARCH}" = "x86_64" ]; then \
        RCLONE_ARCH="amd64"; \
    elif [ "${ARCH}" = "aarch64" ]; then \
        RCLONE_ARCH="arm64"; \
    else \
        RCLONE_ARCH="${ARCH}"; \
    fi && \
    curl -fsSL "https://downloads.rclone.org/rclone-current-linux-${RCLONE_ARCH}.zip" -o /tmp/rclone.zip && \
    cd /tmp && \
    unzip rclone.zip && \
    cp rclone-*-linux-*/rclone /usr/local/bin/rclone && \
    chmod 755 /usr/local/bin/rclone && \
    rm -rf /tmp/rclone*

CMD ["/bin/bash"]
